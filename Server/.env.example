# Server Configuration
PORT=5000
JWT_SECRET=your_jwt_secret_key

# Database
MONGO_URI=your_mongodb_connection_string

# Cloudinary (for profile pictures)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Fitbit API (from https://dev.fitbit.com/)
FITBIT_CLIENT_ID=your_fitbit_client_id
FITBIT_CLIENT_SECRET=your_fitbit_client_secret
FITBIT_CALLBACK_URL=http://localhost:5000/api/dashboard/fitbit/callback

# Google Fit API (from https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/dashboard/google-fit/callback

# Frontend URL (for redirects and CORS)
FRONTEND_URL=http://localhost:5173
