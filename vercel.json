{
    "public": false,
    "buildCommand": "cd Client && npm install && npm run build",
    "outputDirectory": "Client/dist",
    "framework": "vite",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "https://fitness-quest-rpg.onrender.com/api/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}